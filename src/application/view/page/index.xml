{% extends "auth.xml" %}
{% set codice_dsl %}
{% raw %}
{
  tris_logic : {
    c0(default: "") -> tris_logic.c0;
    c1(default: "") -> tris_logic.c1;
    c2(default: "") -> tris_logic.c2;
    c3(default: "") -> tris_logic.c3;
    c4(default: "") -> tris_logic.c4;
    c5(default: "") -> tris_logic.c5;
    c6(default: "") -> tris_logic.c6;
    c7(default: "") -> tris_logic.c7;
    c8(default: "") -> tris_logic.c8;

    turn(default: "O") -> tris_logic.turn;
    
    play_0(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c0", payload: tris_logic.c0 == "" and tris_logic.turn or tris_logic.c0),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_1(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c1", payload: tris_logic.c1 == "" and tris_logic.turn or tris_logic.c1),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_2(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c2", payload: tris_logic.c2 == "" and tris_logic.turn or tris_logic.c2),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_3(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c3", payload: tris_logic.c3 == "" and tris_logic.turn or tris_logic.c3),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_4(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c4", payload: tris_logic.c4 == "" and tris_logic.turn or tris_logic.c4),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_5(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c5", payload: tris_logic.c5 == "" and tris_logic.turn or tris_logic.c5),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_6(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c6", payload: tris_logic.c6 == "" and tris_logic.turn or tris_logic.c6),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_7(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c7", payload: tris_logic.c7 == "" and tris_logic.turn or tris_logic.c7),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];
    play_8(deps:false, on_success: "tris_logic.check_victory") -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c8", payload: tris_logic.c8 == "" and tris_logic.turn or tris_logic.c8),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X") )
    ];

    winner(default: "") -> tris_logic.winner;

    check_victory() -> {
        c0: tris_logic.c0;
        c1: tris_logic.c1;
        c2: tris_logic.c2;
        c3: tris_logic.c3;
        c4: tris_logic.c4;
        c5: tris_logic.c5;
        c6: tris_logic.c6;
        c7: tris_logic.c7;
        c8: tris_logic.c8;
        winner: tris_logic.winner;
    } |> switch({
        @c0 != "" & @winner == "" & @c0 == @c3 & @c3 == @c6: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c1 != "" & @winner == "" & @c1 == @c4 & @c4 == @c7: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c2 != "" & @winner == "" & @c2 == @c5 & @c5 == @c8: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c0 != "" & @winner == "" & @c0 == @c4 & @c4 == @c8: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c2 != "" & @winner == "" & @c2 == @c4 & @c4 == @c6: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c0 != "" & @winner == "" & @c0 == @c1 & @c1 == @c2: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c3 != "" & @winner == "" & @c3 == @c4 & @c4 == @c5: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
        @c6 != "" & @winner == "" & @c6 == @c7 & @c7 == @c8: @messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: (tris_logic.turn == "X" and "O") or (tris_logic.turn == "O" and "X"));
    });

    reset_btn(deps:false) -> [
        messenger.post(session: sid, domain: "tris:tris_logic.c0", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c1", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c2", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c3", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c4", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c5", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c6", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c7", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.c8", payload: ""),
        messenger.post(session: sid, domain: "tris:tris_logic.turn", payload: "X"),
        messenger.post(session: sid, domain: "tris:tris_logic.winner", payload: "")
    ];
  }
}
{% endraw %}
{% endset %}
{% set codice_ui %}
{% raw %}
&lt;Window type="page" title="Tic-Tac-Toe / Gioco del Tris"&gt;
    &lt;Container padding="40px" background="linear-gradient(#0f172a, #1e293b)" min-height="100vh" align="center" justify="center"&gt;
        &lt;Column background="rgba(30, 41, 59, 0.7)" padding="32px" radius="24px" border="1px,rgba(255,255,255,0.1)" matter="glass" shadow="large" width="500px" align="center" spacing="24px"&gt;
            
            &lt;Column align="center" spacing="8px"&gt;
                &lt;Text size="32px" color="rgba(255,255,255,0.9)" font="bold"&gt;Gioco del Tris&lt;/Text&gt;
                
                &lt;Row align="center" spacing="8px"&gt;
                    &lt;Text size="18px" color="#94a3b8"&gt;Turno attuale:&lt;/Text&gt;
                    &lt;Text id="turn_display" bind="tris:tris_logic.turn" size="24px" color="#38bdf8" font="bold"&gt;
                        {{ tris.tris_logic.turn|default('X') }}
                    &lt;/Text&gt;
                &lt;/Row>

                &lt;Text id="winner_display" bind="tris:tris_logic.winner" size="30px" color="#10b981" font="bold"&gt;
                    {{ 'Vincitore: ' + tris.tris_logic.winner|default('') }}
                &lt;/Text&gt;

                &lt;Text&gt;
                    {{ session.user.name }}
                &lt;/Text&gt;

            &lt;/Column&gt;

            &lt;Grid spacing="10px" width="300px" height="300px"&gt;
                &lt;Action click="tris:tris_logic.play_0" id="btn_0" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_0" bind="tris:tris_logic.c0" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c0|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
                &lt;Action click="tris:tris_logic.play_1" id="btn_1" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_1" bind="tris:tris_logic.c1" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c1|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
                &lt;Action click="tris:tris_logic.play_2" id="btn_2" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_2" bind="tris:tris_logic.c2" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c2|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;

                &lt;Action click="tris:tris_logic.play_3" id="btn_3" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_3" bind="tris:tris_logic.c3" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c3|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
                &lt;Action click="tris:tris_logic.play_4" id="btn_4" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_4" bind="tris:tris_logic.c4" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c4|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
                &lt;Action click="tris:tris_logic.play_5" id="btn_5" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_5" bind="tris:tris_logic.c5" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c5|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;

                &lt;Action click="tris:tris_logic.play_6" id="btn_6" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_6" bind="tris:tris_logic.c6" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c6|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
                &lt;Action click="tris:tris_logic.play_7" id="btn_7" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_7" bind="tris:tris_logic.c7" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c7|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
                &lt;Action click="tris:tris_logic.play_8" id="btn_8" background="#1e293b" radius="16px" border="1px,rgba(255,255,255,0.1)" pointer="pointer" width="100%" height="100%" align="center" justify="center"&gt;
                    &lt;Text id="t_8" bind="tris:tris_logic.c8" size="48px" font="bold" color="white"&gt{{ tris.tris_logic.c8|default('') }}&lt;/Text&gt;
                &lt;/Action&gt;
            &lt;/Grid&gt;

            &lt;Divider background="rgba(255,255,255,0.05)" margin="16px,0" width="100%" /&gt;

            &lt;Action click="tris:tris_logic.reset_btn" id="btn_reset" background="#38bdf8" color="#0f172a" padding="12px,32px" radius="12px" font="bold" pointer="pointer"&gt;
                Ricomincia Partita
            &lt;/Action&gt;

        &lt;/Column&gt;
    &lt;/Container&gt;
&lt;/Window&gt;
{% endraw %}
{% endset %}
